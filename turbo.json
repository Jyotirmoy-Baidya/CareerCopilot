{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "REDIS_URL",
    "JWT_SECRET",
    "NEXTAUTH_SECRET",
    "NEXTAUTH_URL",
    "WEB_URL",
    "NEXT_PUBLIC_WS_URL",
    "GEMINI_API_KEY",
    "AUTH_SERVICE_URL",
    "RECOMMENDATION_SERVICE_URL",
    "SYNC_SERVICE_URL",
    "COLLABORATION_SERVICE_URL",
    "AI_SERVICE_URL",
    "NOTIFICATION_SERVICE_URL",
    "WHATSAPP_API_URL",
    "WHATSAPP_TOKEN",
    "GMAIL_USER",
    "GMAIL_APP_PASSWORD",
    "OPENROUTER_API_KEY",
    "PORT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    }
  }
}
