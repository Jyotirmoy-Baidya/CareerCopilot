# Copy this file to .env and fill in real values. Never commit .env.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/careercopliot

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT — one secret, all services verify with it ─────────────────────────────
JWT_SECRET=replace-with-a-random-string-at-least-32-characters

# ── Service ports ─────────────────────────────────────────────────────────────
AUTH_SERVICE_PORT=4001
RECOMMENDATION_SERVICE_PORT=4002
SYNC_SERVICE_PORT=4003
COLLABORATION_SERVICE_PORT=4004
AI_SERVICE_PORT=4005
NOTIFICATION_SERVICE_PORT=4006

# ── Service URLs (used by Next.js to call services) ───────────────────────────
AUTH_SERVICE_URL=http://localhost:4001
RECOMMENDATION_SERVICE_URL=http://localhost:4002
SYNC_SERVICE_URL=http://localhost:4003
COLLABORATION_SERVICE_URL=http://localhost:4004
AI_SERVICE_URL=http://localhost:4005
NOTIFICATION_SERVICE_URL=http://localhost:4006

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=replace-with-another-random-string
NEXTAUTH_URL=http://localhost:3000
WEB_URL=http://localhost:3000

# ── WebSocket — must be NEXT_PUBLIC so the browser can read it ────────────────
NEXT_PUBLIC_WS_URL=ws://localhost:4004

# ── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=get-this-from-google-ai-studio

# ── WhatsApp (optional — leave blank in dev, notification service will mock it)
WHATSAPP_API_URL=
WHATSAPP_TOKEN=
